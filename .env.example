# ============================================================
# Backend (apps/api) — copy to apps/api/.env
# ============================================================

# Optional: Groq API key. Seeds ApiKeyStore at boot.
# If blank, the server still starts and the user pastes their key in the
# Settings drawer (stored in process memory only). Get one at
# https://console.groq.com/keys
GROQ_API_KEY=

# Models (defaults match the assignment spec)
GROQ_TRANSCRIPTION_MODEL=whisper-large-v3
GROQ_LLM_MODEL=openai/gpt-oss-120b

# API server
API_PORT=4000
API_HOST=0.0.0.0

# CORS — comma-separated origins allowed to hit the API
CORS_ORIGINS=http://localhost:3000

# Pipeline tuning
# Approximate audio chunk length the frontend sends (informational, used for logs)
CHUNK_SECONDS=30
# How many recent transcript chunks to feed into suggestion / chat prompts
TRANSCRIPT_CONTEXT_CHUNKS=12
# How many recent chat turns to feed into chat prompts
CHAT_CONTEXT_TURNS=6
# Max tokens for LLM responses (sent to Groq as `max_completion_tokens`)
LLM_MAX_TOKENS=900
# Temperature for suggestion + chat generation
LLM_TEMPERATURE=0.4
# Reasoning effort for GPT-OSS-120B (low | medium | high).
# `low` keeps live 3-suggestion latency tight; chat/expand can use more headroom.
LLM_SUGGESTION_REASONING_EFFORT=low
LLM_CHAT_REASONING_EFFORT=medium

# ============================================================
# Frontend (apps/web) — copy to apps/web/.env.local
# ============================================================

# Public API base URL the browser will call
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# Audio chunk length in seconds (frontend-controlled)
NEXT_PUBLIC_CHUNK_SECONDS=30
